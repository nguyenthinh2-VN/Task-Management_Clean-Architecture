# =============================================
# Task Management – Environment Variables
# Copy file này và đặt tên .env, điền giá trị thực
# KHÔNG commit file .env lên Git
# =============================================

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=task_management_db
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# --- JWT ---
JWT_SECRET=your-very-strong-secret-key-min-32-chars-here
JWT_EXPIRATION_MS=86400000
